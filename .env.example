# Copy to .env.local (gitignored). The key is only ever read in route
# handlers — never exposed via NEXT_PUBLIC_ (spec §3).
OPENAI_API_KEY=sk-...

# Optional: override the model used for chat + grading (lib/config.ts)
# OPENAI_MODEL=gpt-4o-mini

# Optional: persist progress in server-side SQLite instead of localStorage
# NEXT_PUBLIC_PERSIST=sqlite
